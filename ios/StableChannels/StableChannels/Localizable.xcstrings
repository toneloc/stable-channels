    "info_backup_seed" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اكتب هذه الكلمات وقم بتخزينها بأمان. يمكن لأي شخص يمتلك هذه الكلمات الوصول إلى أموالك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই শব্দগুলো লিখে রাখুন এবং নিরাপদে সংরক্ষণ করুন। এই শব্দগুলো যার কাছে আছে সে আপনার তহবিল অ্যাক্সেস করতে পারবে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schreiben Sie diese Wörter auf und verwahren Sie sie sicher. Jeder mit diesen Wörtern hat Zugriff auf Ihr Geld."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Write these words down and store them safely. Anyone with these words can access your funds."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escribe estas palabras y guárdalas con seguridad. Quien las tenga podrá acceder a tus fondos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notez ces mots et conservez-les en sécurité. Quiconque possède ces mots peut accéder à vos fonds."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इन शब्दों को लिख लें। जिसके पास ये शब्द होंगे, वह आपके फंड तक पहुंच सकता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらの単語を書き留めて、安全に保管してください。これらの単語を持つ者は誰でもあなたの資金にアクセスできます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anote estas palavras e guarde-as com segurança. Qualquer pessoa com estas palavras poderá acessar seus fundos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запишите эти слова и храните их в надежном месте. Любой, у кого есть эти слова, может получить доступ к вашим средствам."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写下这些单词并妥善保管。任何人拥有这些单词都可以访问您的资金。"
          }
        }
      }
    },
