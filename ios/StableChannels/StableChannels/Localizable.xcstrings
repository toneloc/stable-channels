            "value": "Carteira restaurada!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041a\u043e\u0448\u0435\u043b\u0435\u043a \u0432\u043e\u0441\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d!"
          }
