    "empty_trades_desc": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0642\u0645 \u0628\u062a\u062d\u0648\u064a\u0644 BTC \u0644\u0631\u0624\u064a\u0629 \u0627\u0644\u0637\u0644\u0628\u0627\u062a \u0647\u0646\u0627"
