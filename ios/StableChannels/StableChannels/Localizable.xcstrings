        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0915\u093f\u0938\u0940 \u092d\u0940 \u092c\u093f\u091f\u0915\u0949\u0907\u0928 \u092a\u0924\u0947 \u092a\u0930 \u092b\u0902\u0921 \u092d\u0947\u091c\u0947\u0902"
