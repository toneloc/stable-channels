    "disclaimer_custody_body" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels هي محفظة بالاستضافة الذاتية. أنت تتحكم في مفاتيحك الخاصة. الأطراف الثالثة لا تمتلك، ولا تصل، ولا تجمد أموالك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels একটি স্ব-হেফাজত ওয়ালেট। আপনি আপনার ব্যক্তিগত কীগুলি নিয়ন্ত্রণ করেন। তৃতীয় পক্ষ আপনার তহবিল হেফাজত, অ্যাক্সেস বা ফ্রিজ করে না।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels ist eine selbstverwaltete Wallet. Sie kontrollieren Ihre privaten Schlüssel. Dritte haben keinen Zugriff und können Ihr Geld nicht einfrieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Stable Channels is a self-custodial wallet. You control your private keys. Third parties do not custody, access, or freeze your funds."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels es una billetera auto-custodiada. Tú controlas tus claves privadas. Los terceros no guardan, acceden ni congelan tus fondos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels est un portefeuille auto-hébergé. Vous contrôlez vos clés privées. Les tiers ne conservent, n'accèdent ni ne gèlent vos fonds."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्टेबल चैनल्स एक स्व-अभिरक्षा (self-custodial) वॉलेट है। आप अपनी निजी कुंजियों को नियंत्रित करते हैं। तृतीय पक्ष आपके फंड को फ्रीज या एक्सेस नहीं करते हैं।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channelsは自己管理型ウォレットです。秘密鍵はご自身で管理します。第三者があなたの資金を保管、アクセス、凍結することはありません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels é uma carteira auto-custodial. Você controla suas chaves privadas. Terceiros não guardam, acessam ou congelam seus fundos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels — это некастодиальный кошелек. Вы полностью контролируете свои приватные ключи. Третьи лица не могут заморозить ваши средства или получить к ним доступ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stable Channels 是一款自托管钱包。您完全控制您的私钥。第三方无法托管、访问或冻结您的资金。"
          }
        }
      }
    },
