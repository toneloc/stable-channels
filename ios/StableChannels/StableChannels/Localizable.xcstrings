    "Wallet restored!": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "\u062a\u0645 \u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0627\u0644\u0645\u062d\u0641\u0638\u0629!"
