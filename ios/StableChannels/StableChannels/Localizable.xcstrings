        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un splice ya est\u00e1 en progreso \u2014 int\u00e9ntalo de nuevo en breve"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un raccordement est d\u00e9j\u00e0 en cours \u2014 r\u00e9essayez sous peu"
