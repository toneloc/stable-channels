    "Restoring from iCloud will erase your existing wallet and all funds. Please withdraw all Bitcoin before proceeding." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استعادة المحفظة من iCloud ستؤدي إلى مسح محفظتك الحالية وجميع الأموال. يرجى سحب كل البيتكوين قبل المتابعة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud থেকে পুনরুদ্ধার করলে আপনার বর্তমান ওয়ালেট এবং সমস্ত তহবিল মুছে যাবে। চালিয়ে যাওয়ার আগে দয়া করে সমস্ত বিটকয়েন প্রত্যাহার করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Wiederherstellung aus iCloud löscht Ihre Wallet. Bitte beheben Sie zuerst alle Bitcoin ab."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La restauración desde iCloud borrará tu billetera y tus fondos. Retira todo tu Bitcoin antes de continuar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La restauration depuis iCloud effacera votre portefeuille. Veuillez retirer tous vos Bitcoins."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud से पुनर्स्थापित करने पर मौजूदा वॉलेट मिट जाएगा। कृपया सभी बिटकॉइन निकाल लें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloudから復元すると、ウォレットと資金が消去されます。続行する前にすべてのビットコインを引き出してください。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A restauração do iCloud apagará sua carteira e todos os fundos. Por favor, retire todos os Bitcoins antes de continuar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Восстановление из iCloud удалит текущий кошелек. Пожалуйста, выведите все биткоины."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从 iCloud 恢复将擦除您现有的钱包和所有资金。请在继续操作前提取所有比特币。"
          }
        }
      }
    },
