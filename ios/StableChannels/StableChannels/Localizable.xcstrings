    "export_description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف كلمة مرور لحماية نسختك الاحتياطية المُصدرة. ستحتاج إليها عند الاستعادة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার এক্সপোর্ট করা ব্যাকআপ সুরক্ষিত করতে একটি পাসফ্রেজ যোগ করুন। পুনরুদ্ধার করতে আপনার এটি প্রয়োজন হবে।"
          }
        },
        "de" : {
          "stringUnit" : {
