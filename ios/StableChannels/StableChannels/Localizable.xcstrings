        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed-\u0444\u0440\u0430\u0437\u0430 \u0434\u043e\u043b\u0436\u043d\u0430 \u0441\u043e\u0441\u0442\u043e\u044f\u0442\u044c \u0438\u0437 12 \u0438\u043b\u0438 24 \u0441\u043b\u043e\u0432"
