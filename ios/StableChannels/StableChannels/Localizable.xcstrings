        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "\u09b8\u09c0\u09a1 \u09ab\u09cd\u09b0\u09c7\u099c \u0985\u09ac\u09b6\u09cd\u09af\u0987 \u09e7\u09e8 \u09ac\u09be \u09e8\u09ea \u09b6\u09ac\u09cd\u09a6\u09c7\u09b0 \u09b9\u09a4\u09c7 \u09b9\u09ac\u09c7"
