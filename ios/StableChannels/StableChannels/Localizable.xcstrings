        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0993\u09af\u09bc\u09be\u09b2\u09c7\u099f \u09aa\u09c1\u09a8\u09b0\u09c1\u09a6\u09cd\u09a7\u09be\u09b0 \u0995\u09b0\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7!"
