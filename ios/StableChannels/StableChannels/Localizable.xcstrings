    "alert_close_channel_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد إغلاق هذه القناة؟"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি কি নিশ্চিত যে আপনি এই চ্যানেলটি বন্ধ করতে চান?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie diesen Kanal wirklich schließen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to close this channel?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que deseas cerrar este canal?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir fermer ce canal ?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आप वाकई इस चैनल को बंद करना चाहते हैं?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このチャネルを閉じてもよろしいですか？"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja fechar este canal?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите закрыть этот канал?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您确定要关闭此通道吗？"
          }
        }
      }
